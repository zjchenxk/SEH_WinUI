<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SEH.Views.ViewScorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SEH.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:viewmodels="using:SEH.ViewModels" 
    d:DataContext="{d:DesignInstance Type=viewmodels:ViewScoreViewModel}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--引用渲染模板资源字典 -->
                <ResourceDictionary Source="/Assets/Themes/ScoreRenderTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <!--工具栏-->
            <RowDefinition Height="Auto"/>
            <!--内容区-->
            <RowDefinition Height="*"/>
            <!--口琴区-->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <CommandBar Background="Transparent" IsOpen="False" DefaultLabelPosition="Right" Padding="0" HorizontalAlignment="Left">
            <AppBarButton Label="编辑简谱" Style="{StaticResource MyAppBarButtonStyle}" Command="{x:Bind ViewModel.EditCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE70F;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="播放简谱" Style="{StaticResource MyAppBarButtonStyle}" Command="{x:Bind ViewModel.PlayCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE768;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="打印简谱" Style="{StaticResource MyAppBarButtonStyle}" Command="{x:Bind ViewModel.PrintCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE749;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="关闭简谱" Style="{StaticResource MyAppBarButtonStyle}" Command="{x:Bind ViewModel.CloseCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7E8;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Border Grid.Row="1" Background="{ThemeResource SystemChromeWhiteColor}" CornerRadius="10" Tapped="ScoreRegion_Tapped">
            <ScrollView HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Top">
                <!--用 Grid 包裹 Border，Grid 会根据内容自适应大小-->
                <Grid>
                    <Border x:Name="ScoreCanvas" BorderBrush="{ThemeResource SystemChromeHighColor}" BorderThickness="1" Margin="40"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.RenderElements, Mode=OneWay}"
                                      ItemTemplateSelector="{StaticResource ScoreTemplateSelector}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid Width="{Binding Width, Mode=OneWay}" Height="{Binding Height, Mode=OneWay}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </Grid>
            </ScrollView>
        </Border>

        <Grid Grid.Row="2" Height="200" Padding="15" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--吹音-->
            <Grid Grid.Row="0" Grid.Column="0" Width="60" Height="60"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <TextBlock  Text="吹音" FontSize="{StaticResource TextStyleLargeFontSize}"/>
            </Grid>

            <Border Grid.Row="0" Grid.Column="1" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="1,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                    CornerRadius="8,0,0,0">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="3" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="4" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="5" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="6" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="7" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="8" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="9" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="10" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="11" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="12" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,1,1,0"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                    CornerRadius="0,8,0,0">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Grid Grid.Row="0" Grid.Column="13" Width="60" Height="60">

            </Grid>

            <Grid Grid.Row="0" Grid.Column="14" Width="60" Height="60">

            </Grid>

            <!--吹孔-->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="2,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="2"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="3"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="4"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="5"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="6"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="7"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="8"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="9"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="10"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="11"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="12"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="13"
                    Background="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="0,2,2,0"
                    BorderBrush="{ThemeResource SystemFillColorSolidNeutralBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="14" Width="60" Height="60">

            </Grid>

            <!--吸音-->
            <Grid Grid.Row="2" Grid.Column="0" Width="60" Height="60"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <TextBlock  Text="吸音" FontSize="{StaticResource TextStyleLargeFontSize}"/>
            </Grid>

            <Border Grid.Row="2" Grid.Column="1" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="1,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                    CornerRadius="0,0,0,8">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="3" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="4" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="5" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="6" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="7" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="8" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="9" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="10" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="11" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="12" 
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderThickness="0,0,1,1"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                    CornerRadius="0,0,8,0">
                <Grid Width="60" Height="60">

                </Grid>
            </Border>

            <Grid Width="60" Height="60" Grid.Row="2" Grid.Column="13">

            </Grid>

            <Grid Width="60" Height="60" Grid.Row="2" Grid.Column="14">

            </Grid>

        </Grid>
    </Grid>
</Page>
