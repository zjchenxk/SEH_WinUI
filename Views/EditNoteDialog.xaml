<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="SEH.Views.EditNoteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SEH.Views"
    xmlns:controls="using:SEH.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="录入音符"
    PrimaryButtonText="确定"
    SecondaryButtonText="取消"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">600</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">800</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="800" VerticalScrollBarVisibility="Auto">
        <Grid ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--音符-->
            <StackPanel Grid.Column="0" Grid.Row="0" HorizontalAlignment="Stretch">
                <ComboBox Header="音符：" PlaceholderText="选择音符..."
                          SelectedValuePath="Tag"
                          SelectedValue="{x:Bind ViewModel.Pitch, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">

                    <ComboBoxItem Content="中音音符１" Tag="1"/>
                    <ComboBoxItem Content="中音音符２" Tag="2"/>
                    <ComboBoxItem Content="中音音符３" Tag="3"/>
                    <ComboBoxItem Content="中音音符４" Tag="4"/>
                    <ComboBoxItem Content="中音音符５" Tag="5"/>
                    <ComboBoxItem Content="中音音符６" Tag="6"/>
                    <ComboBoxItem Content="中音音符７" Tag="7"/>

                    <ComboBoxItem Content="低音音符１" Tag="-1"/>
                    <ComboBoxItem Content="低音音符２" Tag="-2"/>
                    <ComboBoxItem Content="低音音符３" Tag="-3"/>
                    <ComboBoxItem Content="低音音符４" Tag="-4"/>
                    <ComboBoxItem Content="低音音符５" Tag="-5"/>
                    <ComboBoxItem Content="低音音符６" Tag="-6"/>
                    <ComboBoxItem Content="低音音符７" Tag="-7"/>

                    <ComboBoxItem Content="倍低音符１" Tag="--1"/>
                    <ComboBoxItem Content="倍低音符２" Tag="--2"/>
                    <ComboBoxItem Content="倍低音符３" Tag="--3"/>
                    <ComboBoxItem Content="倍低音符４" Tag="--4"/>
                    <ComboBoxItem Content="倍低音符５" Tag="--5"/>
                    <ComboBoxItem Content="倍低音符６" Tag="--6"/>
                    <ComboBoxItem Content="倍低音符７" Tag="--7"/>

                    <ComboBoxItem Content="超低音符１" Tag="---1"/>
                    <ComboBoxItem Content="超低音符２" Tag="---2"/>
                    <ComboBoxItem Content="超低音符３" Tag="---3"/>
                    <ComboBoxItem Content="超低音符４" Tag="---4"/>
                    <ComboBoxItem Content="超低音符５" Tag="---5"/>
                    <ComboBoxItem Content="超低音符６" Tag="---6"/>
                    <ComboBoxItem Content="超低音符７" Tag="---7"/>

                    <ComboBoxItem Content="高音音符１" Tag="+1"/>
                    <ComboBoxItem Content="高音音符２" Tag="+2"/>
                    <ComboBoxItem Content="高音音符３" Tag="+3"/>
                    <ComboBoxItem Content="高音音符４" Tag="+4"/>
                    <ComboBoxItem Content="高音音符５" Tag="+5"/>
                    <ComboBoxItem Content="高音音符６" Tag="+6"/>
                    <ComboBoxItem Content="高音音符７" Tag="+7"/>

                    <ComboBoxItem Content="倍高音符１" Tag="++1"/>
                    <ComboBoxItem Content="倍高音符２" Tag="++2"/>
                    <ComboBoxItem Content="倍高音符３" Tag="++3"/>
                    <ComboBoxItem Content="倍高音符４" Tag="++4"/>
                    <ComboBoxItem Content="倍高音符５" Tag="++5"/>
                    <ComboBoxItem Content="倍高音符６" Tag="++6"/>
                    <ComboBoxItem Content="倍高音符７" Tag="++7"/>

                    <ComboBoxItem Content="超高音符１" Tag="+++1"/>
                    <ComboBoxItem Content="超高音符２" Tag="+++2"/>
                    <ComboBoxItem Content="超高音符３" Tag="+++3"/>
                    <ComboBoxItem Content="超高音符４" Tag="+++4"/>
                    <ComboBoxItem Content="超高音符５" Tag="+++5"/>
                    <ComboBoxItem Content="超高音符６" Tag="+++6"/>
                    <ComboBoxItem Content="超高音符７" Tag="+++7"/>

                    <ComboBoxItem Content="休止符[0]" Tag="0"/>
                    <ComboBoxItem Content="噪音符[X]" Tag="X"/>
                    <ComboBoxItem Content="增时符[-]" Tag="-"/>
                    <ComboBoxItem Content="空白符[ ]" Tag="_"/>
                </ComboBox>

                <!--红字错误提示，绑定到 ViewModel 的 PitchError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.PitchError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--时值-->
            <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch">
                <ComboBox Header="时值：" PlaceholderText="选择音符时值..."
                          SelectedValuePath="Tag"
                          SelectedValue="{x:Bind ViewModel.Duration, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="全音符" Tag="4"/>
                    <ComboBoxItem Content="二分音符" Tag="2"/>
                    <ComboBoxItem Content="四分音符" Tag="1"/>
                    <ComboBoxItem Content="八分音符" Tag="0.5"/>
                    <ComboBoxItem Content="十六分音符" Tag="0.25"/>
                    <ComboBoxItem Content="三十二分音符" Tag="0.125"/>
                </ComboBox>

                <!--红字错误提示，绑定到 ViewModel 的 DurationError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.DurationError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--附点数量-->
            <StackPanel Grid.Column="0" Grid.Row="2" HorizontalAlignment="Stretch">
                <NumberBox Header="附点数量：" PlaceholderText="输入附点数量..."
                           Value="{x:Bind ViewModel.Dots, Mode=TwoWay}"
                           Minimum="0"
                           Maximum="3"
                           HorizontalAlignment="Stretch"/>

                <!--红字错误提示，绑定到 ViewModel 的 DotsError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.DotsError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--延长号标志-->
            <StackPanel Grid.Column="0" Grid.Row="3" HorizontalAlignment="Stretch">
                <ComboBox Header="延长号标志：" PlaceholderText="选择延长号标志..."
                          SelectedValuePath="Tag"
                          SelectedValue="{x:Bind ViewModel.Fermata, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="有延长号" Tag="1"/>
                    <ComboBoxItem Content="无延长号" Tag="0"/>
                </ComboBox>

                <!--红字错误提示，绑定到 ViewModel 的 FermataError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.FermataError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--开始连音线-->
            <StackPanel Grid.Column="0" Grid.Row="4" HorizontalAlignment="Stretch">
                <controls:MultiSelectComboBox Header="开始连音线：" PlaceholderText="选择开始的连音线..."
                                              ItemsSource="{x:Bind ViewModel.Slurs}"
                                              SelectedItems="{x:Bind ViewModel.SelectedStartSlurs, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              Delimiter=", "
                                              HorizontalAlignment="Stretch"/>

                <!--红字错误提示，绑定到 ViewModel 的 SelectedStartSlursError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.SelectedStartSlursError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--演奏方式-->
            <StackPanel Grid.Column="0" Grid.Row="5" HorizontalAlignment="Stretch">
                <ComboBox Header="演奏方式：" PlaceholderText="选择演奏方式..."
                          SelectedItem="{x:Bind ViewModel.Articulation, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <x:String>倚音</x:String>
                    <x:String>颤音</x:String>
                    <x:String>波音</x:String>
                    <x:String>回音</x:String>
                    <x:String>滑音</x:String>
                    <x:String>琶音</x:String>
                    <x:String>震音</x:String>
                </ComboBox>

                <!--红字错误提示，绑定到 ViewModel 的 ArticulationError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.ArticulationError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--圆括号标志-->
            <StackPanel Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch">
                <ComboBox Header="圆括号标志：" PlaceholderText="选择圆括号标志..."
                          SelectedValuePath="Tag"
                          SelectedValue="{x:Bind ViewModel.Paren, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="无括号" Tag="" IsSelected="True"/>
                    <ComboBoxItem Content="左括号" Tag="1"/>
                    <ComboBoxItem Content="右括号" Tag="0"/>
                </ComboBox>

                <!--红字错误提示，绑定到 ViewModel 的 ParenError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.ParenError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--减时组合-->
            <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch">
                <ComboBox Header="减时组合" PlaceholderText="选择减时组合..."
                          ItemsSource="{x:Bind ViewModel.Beams, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedBeam, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          HorizontalAlignment="Stretch"/>

                <!--红字错误提示，绑定到 ViewModel 的 SelectedBeamError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.SelectedBeamError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--歌词-->
            <StackPanel Grid.Column="1" Grid.Row="2" HorizontalAlignment="Stretch">
                <TextBox Header="歌词：" PlaceholderText="输入歌词..."
                         Text="{x:Bind ViewModel.Lyrics, Mode=TwoWay}"
                         HorizontalAlignment="Stretch"/>

                <!--红字错误提示，绑定到 ViewModel 的 LyricsError 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.LyricsError, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--歌词2-->
            <StackPanel Grid.Column="1" Grid.Row="3" HorizontalAlignment="Stretch">
                <TextBox Header="歌词2：" PlaceholderText="输入歌词..."
                         Text="{x:Bind ViewModel.Lyrics2, Mode=TwoWay}"
                         HorizontalAlignment="Stretch"/>

                <!--红字错误提示，绑定到 ViewModel 的 Lyrics2Error 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.Lyrics2Error, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--歌词3-->
            <StackPanel Grid.Column="1" Grid.Row="4" HorizontalAlignment="Stretch">
                <TextBox Header="歌词3：" PlaceholderText="输入歌词..."
                         Text="{x:Bind ViewModel.Lyrics3, Mode=TwoWay}"
                         HorizontalAlignment="Stretch"/>

                <!--红字错误提示，绑定到 ViewModel 的 Lyrics3Error 属性-->
                <!--如果没有错误，该属性为 null，TextBlock 会自动隐藏-->
                <TextBlock Text="{x:Bind ViewModel.Lyrics3Error, Mode=OneWay}"
                           Foreground="{StaticResource SystemErrorTextColor}"
                           FontSize="{StaticResource ToolTipContentThemeFontSize}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</ContentDialog>
