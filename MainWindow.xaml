            <TextBlock Text="{x:Bind ViewModel.Count, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                       FontSize="48" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>


            -->
        <!--三个按钮的 Command 属性分别绑定到自动生成的命令-->
        <!--
            <Button Content="增加 (+)" 
                    Command="{x:Bind ViewModel.IncrementCommand}"
                    Height="40" 
                    Margin="0,5"
                    Background="LightGreen"/>

            <Button Content="减少 (-)" 
                    Command="{x:Bind ViewModel.DecrementCommand}"
                    Height="40" 
                    Margin="0,5"
                    Background="LightCoral"/>

            <Button Content="重置" 
                    Command="{x:Bind ViewModel.ResetCommand}"
                    Height="40" 
                    Margin="0,5"
                    Background="LightGray"/>
        </StackPanel>-->

    </Grid>
</Window>
