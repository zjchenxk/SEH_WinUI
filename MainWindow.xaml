<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SEH.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SEH"
    xmlns:viewmodels="using:SEH.ViewModels"
    xmlns:views="using:SEH.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="So Easy 口琴">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <!--标题栏-->
            <RowDefinition Height="Auto"/>
            <!--内容区-->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <!--自定义标题栏样式-->
            <Style x:Key="MyTitleBarStyle" TargetType="TitleBar">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TitleBar">
                            <Grid Background="{TemplateBinding Background}" Height="56">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 图标和标题区域 -->
                                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="12" Padding="20,0,0,0">
                                    <!-- 图标 -->
                                    <ContentControl Content="{TemplateBinding IconSource}" Width="48" Height="48" VerticalAlignment="Center">
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate>
                                                <Image Source="{Binding ImageSource}" Width="48" Height="48" Stretch="Uniform"/>
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>
                                    <!-- 标题 -->
                                    <TextBlock Text="{TemplateBinding Title}"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- 自定义内容区域 -->
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                Grid.Column="1"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Margin="20,0"/>

                                <!-- 底部边框 -->
                                <Border VerticalAlignment="Bottom"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        BorderBrush="{ThemeResource TextControlForeground}"
                                        BorderThickness="0,0,0,1"/>

                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--树形列表文件夹节点模板-->
            <DataTemplate x:Key="FolderTemplate" x:DataType="viewmodels:ScoreItem">
                <TreeViewItem AutomationProperties.Name="{x:Bind Name}" 
                              AutomationProperties.AutomationId="{x:Bind Id}"
                              ItemsSource="{x:Bind Children}" 
                              IsExpanded="True">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="32" Source="/Assets/Images/关闭文件夹.png"/>
                        <TextBlock Margin="0,0,10,0"/>
                        <TextBlock Text="{x:Bind Name}"/>
                    </StackPanel>
                </TreeViewItem>
            </DataTemplate>

            <!--树形列表简谱文件节点模板-->
            <DataTemplate x:Key="FileTemplate" x:DataType="viewmodels:ScoreItem">
                <TreeViewItem AutomationProperties.Name="{x:Bind Name}" 
                              AutomationProperties.AutomationId="{x:Bind Id}">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="32" Source="/Assets/Images/查看乐谱.png"/>
                        <TextBlock Margin="0,0,10,0"/>
                        <TextBlock Text="{x:Bind Name}"/>
                    </StackPanel>
                </TreeViewItem>
            </DataTemplate>

            <!--树形列表节点选择器模板-->
            <viewmodels:ScoreItemTemplateSelector x:Key="ScoreItemTemplateSelector"
                                                  FolderTemplate="{StaticResource FolderTemplate}"
                                                  FileTemplate="{StaticResource FileTemplate}"/>
        </Grid.Resources>

        <!--标题栏-->
        <TitleBar x:Name="AppTitleBar" Title="So Easy 口琴" 
                  IsBackButtonVisible="False" 
                  IsPaneToggleButtonVisible="False"
                  Style="{StaticResource MyTitleBarStyle}">

            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Images/口琴48.png" />
            </TitleBar.IconSource>

            <TitleBar.Content>
                <CommandBar Background="Transparent" IsOpen="False" DefaultLabelPosition="Right">
                    <AppBarButton Label="新增类别" Style="{StaticResource MyAppBarButtonStyle}">
                        <AppBarButton.Icon>
                            <BitmapIcon UriSource="/Assets/Images/添加.png" ShowAsMonochrome="False"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="修改类别" Style="{StaticResource MyAppBarButtonStyle}">
                        <AppBarButton.Icon>
                            <BitmapIcon UriSource="/Assets/Images/修改.png" ShowAsMonochrome="False"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="删除类别" Style="{StaticResource MyAppBarButtonStyle}">
                        <AppBarButton.Icon>
                            <BitmapIcon UriSource="/Assets/Images/删除.png" ShowAsMonochrome="False"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator/>
                    <AppBarButton Label="新增简谱" Style="{StaticResource MyAppBarButtonStyle}">
                        <AppBarButton.Icon>
                            <BitmapIcon UriSource="/Assets/Images/添加.png" ShowAsMonochrome="False"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="修改简谱" Style="{StaticResource MyAppBarButtonStyle}">
                        <AppBarButton.Icon>
                            <BitmapIcon UriSource="/Assets/Images/修改.png" ShowAsMonochrome="False"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="删除简谱" Style="{StaticResource MyAppBarButtonStyle}">
                        <AppBarButton.Icon>
                            <BitmapIcon UriSource="/Assets/Images/删除.png" ShowAsMonochrome="False"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="移动简谱" Style="{StaticResource MyAppBarButtonStyle}">
                        <AppBarButton.Icon>
                            <BitmapIcon UriSource="/Assets/Images/移动.png" ShowAsMonochrome="False"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
            </TitleBar.Content>
        </TitleBar>

        <SplitView Grid.Row="1" 
                   IsPaneOpen="True" 
                   DisplayMode="Inline" 
                   OpenPaneLength="300">
            <SplitView.Pane>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--树形列表标题-->
                    <TextBlock x:Name="PaneHeader" 
                               Margin="20,10" 
                               Style="{StaticResource SubtitleTextBlockStyle}" 
                               Text="我的简谱"/>

                    <!--简谱树形列表-->
                    <TreeView x:Name="ScoreTreeView"
                              Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.ScoreItems}"
                              ItemTemplateSelector="{StaticResource ScoreItemTemplateSelector}"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"/>
                </Grid>
            </SplitView.Pane>

            <!--工作区-->
            <Frame x:Name="rootFrame" SourcePageType="views:HomePage"/>

        </SplitView>
    </Grid>
</Window>
