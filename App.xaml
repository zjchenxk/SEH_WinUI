<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="SEH.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SEH"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- 核心正文 -->
            <!-- 默认 14 -->
            <x:Double x:Key="ContentControlFontSize">22</x:Double>
            <!-- 默认 14 -->
            <x:Double x:Key="TextBlockFontSize">22</x:Double>

            <!-- 排版体系 字体放大 -->
            <!-- 以下是 WinUI 3 的默认值，你可以将其调大 -->
            <!-- 默认 20 -->
            <x:Double x:Key="SubtitleFontSize">30</x:Double>
            <!-- 默认 28 -->
            <x:Double x:Key="TitleFontSize">42</x:Double>
            <!-- 默认 40 -->
            <x:Double x:Key="TitleLargeFontSize">60</x:Double>
            <!-- 默认 46 -->
            <x:Double x:Key="HeaderFontSize">70</x:Double>
            <!-- 默认 34 -->
            <x:Double x:Key="SubheaderFontSize">52</x:Double>
            <!-- 默认 14 -->
            <x:Double x:Key="BodyFontSize">22</x:Double>
            <!-- 默认 12 -->
            <x:Double x:Key="CaptionFontSize">18</x:Double>
            <!-- 默认 14 -->
            <x:Double x:Key="BodyStrongFontSize">22</x:Double>
            <!-- 默认 12 -->
            <x:Double x:Key="SubtleFontSize">18</x:Double>

            <Style TargetType="TitleBar">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TitleBar">
                            <Grid Background="{TemplateBinding Background}" Height="56">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 图标和标题区域 -->
                                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="12" Padding="20,0,0,0">
                                    <!-- 图标 -->
                                    <ContentControl Content="{TemplateBinding IconSource}" Width="48" Height="48" VerticalAlignment="Center">
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate>
                                                <Image Source="{Binding ImageSource}" Width="48" Height="48" Stretch="Uniform"/>
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>
                                    <!-- 标题 -->
                                    <TextBlock Text="{TemplateBinding Title}"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- 自定义内容区域 -->
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                Grid.Column="1"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Margin="20,0"/>

                                <!-- 底部边框 -->
                                <Border VerticalAlignment="Bottom"
                                        Grid.ColumnSpan="2"
                                        Height="1"
                                        BorderBrush="{ThemeResource TextControlForeground}"
                                        BorderThickness="0,0,0,1"/>

                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="{ThemeResource TextBlockFontSize}"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="RichEditBox">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="AppBarButton">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="AppBarToggleButton">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="ToggleSwitch">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="RadioButton">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="ListBoxItem">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="ListViewItem">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="MenuFlyoutItem">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="TreeViewItem">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="ToolTip">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="HyperlinkButton">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
            <Style TargetType="RepeatButton">
                <Setter Property="FontSize" Value="{ThemeResource BodyFontSize}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
